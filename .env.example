# WebSocket multiplayer — local dev
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Production (after Fly.io deploy of ws-server):
# NEXT_PUBLIC_WS_URL=wss://surf-3d-ws.fly.dev
# LEADERBOARD_API_URL=https://surf-3d-ws.fly.dev

# Global leaderboard persistence on Vercel (Vercel Blob store — optional)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Fallback: proxy leaderboard to ws-server HTTP API
LEADERBOARD_API_URL=http://localhost:3001

# WS server port (local / Fly internal)
WS_PORT=3001

# Fly.io volume mount path for persistent leaderboard file
# LEADERBOARD_DATA_DIR=/data